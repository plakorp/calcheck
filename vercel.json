{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["sin1"],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "checkkal.com" }],
      "destination": "https://www.checkkal.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/google-index",
      "schedule": "0 2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
